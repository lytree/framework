	<ItemGroup>
		<PackageReference Include="TUnit" Version="1.41.0" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\src\Framework.ZLogging\Framework.ZLogging.csproj" />
	</ItemGroup>
</Project>